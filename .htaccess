# Cache-Control — evita que visitantes fiquem presos a uma versao antiga em cache
<IfModule mod_headers.c>
  # HTML: revalidar sempre, para sempre servir a versao mais recente
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  # Assets estaticos (versionados via ?v=): cache longo, seguro
  <FilesMatch "\.(css|js|jpe?g|png|gif|svg|webp|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Compressao gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/xml image/svg+xml
</IfModule>
